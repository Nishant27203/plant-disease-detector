FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=replace-with-a-long-random-secret
MODEL_PATH=ai_model/model.onnx
MAX_UPLOAD_MB=8
IMAGE_SIZE=224
NORMALIZATION_MODE=imagenet
REQUIRE_API_KEY=0
API_KEY=
GRADCAM_GRID_SIZE=10
# Finer heatmaps: more patches (slower). Capped for CPU latency.
GRADCAM_MAX_PATCHES=384
GRADCAM_BATCH_CHUNK=48
